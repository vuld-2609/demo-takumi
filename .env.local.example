# Supabase configuration
# Get these from your Supabase project: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Authoritative public base URL of this app (used to build the OAuth redirect).
# Set this in production (e.g. https://your-domain.com). Locally defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Target date/time the /countdown page counts down to (ISO 8601, include timezone).
# Example: the SAA 2025 event start. Falls back to a placeholder if unset.
NEXT_PUBLIC_COUNTDOWN_TARGET=2026-12-31T18:00:00+07:00

# After filling the values above:
# 1. In Supabase Dashboard → Authentication → Providers → Google: enable Google, add OAuth credentials
# 2. In Supabase Dashboard → Authentication → URL Configuration → Redirect URLs: add http://localhost:3000/auth/callback
#    (and your production URL, e.g. https://your-domain.com/auth/callback)
# 3. Copy this file to .env.local and fill in the values
