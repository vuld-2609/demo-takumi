# Supabase configuration
# Get these from your Supabase project: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Authoritative public base URL of this app (used to build the OAuth redirect).
# Set this in production (e.g. https://your-domain.com). Locally defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Homepage countdown target — ISO-8601 datetime the hero counts down to.
# Used by the homepage (lib/countdown.ts). If unset or invalid, it falls back
# to 2026-12-26T18:30:00+07:00 (no crash). At/after the target, the timer shows
# 00 00 00 and the "Coming soon" label is hidden.
NEXT_PUBLIC_EVENT_DATETIME=2026-12-26T18:30:00+07:00

# RESERVED — not currently used. The /countdown page presently loops a 99-day
# countdown (ticking down one minute at a time). To count toward a real event
# date instead, wire this ISO 8601 value into app/countdown/_components/countdown-timer.tsx.
# NEXT_PUBLIC_COUNTDOWN_TARGET=2026-12-31T18:00:00+07:00

# After filling the values above:
# 1. In Supabase Dashboard → Authentication → Providers → Google: enable Google, add OAuth credentials
# 2. In Supabase Dashboard → Authentication → URL Configuration → Redirect URLs: add http://localhost:3000/auth/callback
#    (and your production URL, e.g. https://your-domain.com/auth/callback)
# 3. Copy this file to .env.local and fill in the values
